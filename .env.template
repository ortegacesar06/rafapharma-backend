# Copia este archivo a `.env` y rellena los valores.
# El docker-compose.yml local provisiona Postgres y Redis con los defaults de abajo.

# Base de datos
DATABASE_URL=postgres://rafapharma:rafapharma@localhost:5432/rafapharma_medusa

# Cache / event bus
REDIS_URL=redis://localhost:6379

# Secrets (cambiar en producción)
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret

# CORS
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:8000

# Brevo (notificaciones email — D10).
# Si BREVO_API_KEY no está seteado, el módulo de notificación NO se carga (dev/test).
# BREVO_API_KEY=
# BREVO_FROM_EMAIL=no-reply@rafapharma.ec
# BREVO_FROM_NAME=Rafapharma
# BREVO_REPLY_TO_EMAIL=
# BREVO_REPLY_TO_NAME=
# IDs numéricos de templates en Brevo (panel → Email → Templates).
# BREVO_TEMPLATE_ORDER_PLACED=
# BREVO_TEMPLATE_ORDER_SHIPPED=
# BREVO_TEMPLATE_ORDER_DELIVERED=
# BREVO_TEMPLATE_PASSWORD_RESET=
# Templates Fase 9.A (transferencia manual).
# BREVO_TEMPLATE_BANK_TRANSFER_INSTRUCTIONS=
# BREVO_TEMPLATE_BANK_TRANSFER_PROOF_RECEIVED=
# BREVO_TEMPLATE_BANK_TRANSFER_CONFIRMED=
# BREVO_TEMPLATE_BANK_TRANSFER_REJECTED=
# Listas Brevo. BREVO_DEFAULT_LIST_ID = lista donde se sincronizan todos los customers nuevos.
# BREVO_LIST_<NOMBRE>=<id> mapea segmentos simbólicos (lower-cased, _ → -) a list ids;
# se usa para `flash_promotion.notification_segment`. Ej: BREVO_LIST_VIP=99 → segment "vip".
# BREVO_DEFAULT_LIST_ID=
# BREVO_LIST_VIP=

# AI Assistant — Fase 7. Si ANTHROPIC_API_KEY o VOYAGE_API_KEY no están seteadas,
# las llamadas LLM/embeddings fallan (el módulo se carga pero falla en runtime).
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5
# VOYAGE_API_KEY=
# VOYAGE_MODEL=voyage-3-lite
# Rate limits para POST /store/chat/messages (mensajes/hora).
# CHAT_RATE_LIMIT_PER_HOUR_IP=20
# CHAT_RATE_LIMIT_PER_HOUR_CUSTOMER=60

# Pagos — Fase 9.A: transferencia bancaria manual.
# Si BANK_TRANSFER_ACCOUNT_NUMBER no está seteado, el provider NO se carga (dev/test sin pagos).
# Referencia generada al iniciar el pago: <REFERENCE_PREFIX>-<order.display_id>-<6 hex>.
# BANK_TRANSFER_ACCOUNT_NAME=Rafapharma S.A.
# BANK_TRANSFER_ACCOUNT_NUMBER=
# BANK_TRANSFER_BANK_NAME=Banco Pichincha
# BANK_TRANSFER_RUC=
# BANK_TRANSFER_REFERENCE_PREFIX=RP

# File module (uploads de comprobantes de pago — Fase 9.A.2).
# FILE_UPLOAD_DIR=static
# MEDUSA_BACKEND_URL=http://localhost:9000

# Tests (copiar a `.env.test` con DB distinta a la de dev).
# El runner de @medusajs/test-utils lee DB_* (no DATABASE_URL) para crear/limpiar la DB de test.
# DATABASE_URL=postgres://rafapharma:rafapharma@localhost:5432/rafapharma_medusa_test
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=rafapharma
# DB_PASSWORD=rafapharma
# DB_TEMP_NAME=rafapharma_medusa_test
